# LastMinute Life Saver - Secrets Configuration
# Declare custom API credentials here. 

# NVIDIA NIM API Key
NVIDIA_API_KEY=

# Ollama Cloud API Key
OLLAMA_API_KEY=

# Gemini API Key (Voice Assist & Routing)
GEMINI_API_KEY=

# Optional: Disable fallback routing (set to false to force errors on primary failure)
AUTO_FALLBACK=true
